# 🔒 AlertHub Enterprise - Secure Production Configuration
# Copy this file to .env and update with your actual values

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# CRITICAL SECURITY CONFIGURATION
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# JWT Security (REQUIRED - Generate with: openssl rand -base64 64)
JWT_SECRET=REPLACE_WITH_64_BYTE_BASE64_ENCODED_SECRET
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_64_BYTE_BASE64_ENCODED_SECRET

# Encryption Key (REQUIRED - Generate with: openssl rand -base64 32)
ENCRYPTION_KEY=REPLACE_WITH_32_BYTE_BASE64_ENCODED_KEY

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# DATABASE CONFIGURATION (PostgreSQL)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

DB_HOST=localhost
DB_PORT=5432
DB_USER=alerthub
DB_PASSWORD=REPLACE_WITH_SECURE_DATABASE_PASSWORD
DB_NAME=alerthub
DB_SSL_MODE=require

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# REDIS CACHE CONFIGURATION
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=REPLACE_WITH_SECURE_REDIS_PASSWORD
REDIS_DB=0

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# APPLICATION SECURITY SETTINGS
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# NEVER set to true in production
DEV_MODE=false

# Session configuration
SESSION_TIMEOUT_MINUTES=480
MAX_LOGIN_ATTEMPTS=5
RATE_LIMIT_PER_MINUTE=60

# Password policy
PASSWORD_MIN_LENGTH=12
PASSWORD_COMPLEXITY=true

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# APPLE OIDC OAUTH 2.0 (Sign in with MAS / OIDC Provider)
# App ID: 961469 | OIDC Portal: https://oidc.example.com/app
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# OAuth Client ID from OIDC (NOT the App ID 961469)
OAUTH_CLIENT_ID=7jdvu5f1gxuuckpbdb5s7jw6tcwpf3
# OAuth Client Secret from OIDC — store in K8s secret, never commit actual value
OAUTH_CLIENT_SECRET=REPLACE_WITH_OIDC_CLIENT_SECRET
# Callback URL — must exactly match the redirect URI registered in OIDC portal
OAUTH_CALLBACK_URL=https://aileron.example.com/api/v1/auth
APP_BASE_URL=https://aileron.example.com
OIDC_PROVIDER_URL=

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# LDAP CONFIGURATION (Optional)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

LDAP_ENABLED=false
LDAP_HOST=ldap.company.com
LDAP_PORT=636
LDAP_USE_TLS=true
LDAP_BIND_DN=cn=admin,dc=company,dc=com
LDAP_BIND_PASSWORD=REPLACE_WITH_LDAP_BIND_PASSWORD
LDAP_USER_BASE_DN=ou=users,dc=company,dc=com
LDAP_GROUP_BASE_DN=ou=groups,dc=company,dc=com

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# MONITORING & INTEGRATIONS
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Dynatrace
DYNATRACE_ENV_ID=your-dynatrace-environment-id
DYNATRACE_API_TOKEN=REPLACE_WITH_DYNATRACE_API_TOKEN

# Prometheus  
PROMETHEUS_URL=http://prometheus.monitoring.svc.cluster.local:9090
PROMETHEUS_AUTH_TOKEN=REPLACE_WITH_PROMETHEUS_TOKEN

# PagerDuty
PAGERDUTY_API_KEY=REPLACE_WITH_PAGERDUTY_API_KEY
PAGERDUTY_ROUTING_KEY=REPLACE_WITH_PAGERDUTY_ROUTING_KEY

# Slack
SLACK_BOT_TOKEN=REPLACE_WITH_SLACK_BOT_TOKEN
SLACK_WEBHOOK_URL=REPLACE_WITH_SLACK_WEBHOOK_URL

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# SECURITY HEADERS & TLS
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# TLS Configuration
TLS_CERT_PATH=/etc/ssl/certs/alerthub.crt
TLS_KEY_PATH=/etc/ssl/private/alerthub.key
TLS_MIN_VERSION=1.3

# CORS Configuration
CORS_ALLOWED_ORIGINS=https://your-domain.com,https://your-staging.com
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Authorization,Content-Type,X-Requested-With

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# LOGGING & MONITORING
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

LOG_LEVEL=INFO
LOG_FORMAT=json
AUDIT_LOG_ENABLED=true
SECURITY_LOG_ENABLED=true

# Metrics & Health
METRICS_ENABLED=true
HEALTH_CHECK_ENABLED=true
PROMETHEUS_METRICS_PATH=/metrics

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# SECURITY GENERATION COMMANDS
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Generate secure secrets:
# JWT_SECRET: openssl rand -base64 64
# JWT_REFRESH_SECRET: openssl rand -base64 64
# ENCRYPTION_KEY: openssl rand -base64 32
# DB_PASSWORD: openssl rand -base64 32
# REDIS_PASSWORD: openssl rand -base64 32

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# KAFKA MESSAGE QUEUE
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

KAFKA_BROKERS=alerthub-kafka-kafka-bootstrap.aileron.svc.cluster.local:9092
# Topics (auto-created by the pipeline; reference only)
# raw-alerts          — inbound from webhooks + universal-alert-gateway
# normalized-alerts   — published after DB persistence
# correlation-results — published after 4-strategy correlation

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# NEO4J GRAPH DATABASE (topology correlation)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

NEO4J_URL=bolt://neo4j.aileron.svc.cluster.local:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=REPLACE_WITH_NEO4J_PASSWORD

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# WEAVIATE VECTOR DATABASE (semantic correlation)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

WEAVIATE_URL=http://weaviate.aileron.svc.cluster.local:8080
WEAVIATE_API_KEY=

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# OLLAMA LOCAL LLM (semantic fallback — optional)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

OLLAMA_URL=http://ollama.aileron.svc.cluster.local:11434
OLLAMA_MODEL=llama2

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# AI MICROSERVICES (all optional — circuit-breaker protected)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

AUTONOMOUS_CORRELATION_URL=http://autonomous-ai-correlation.aileron.svc.cluster.local:8005
AI_CORRELATION_URL=http://ai-correlation-engine.aileron.svc.cluster.local:8002
VECTOR_EMBEDDING_URL=http://vector-embedding-service.aileron.svc.cluster.local:80
AI_INVESTIGATION_ENGINE_URL=http://ai-investigation-engine.aileron.svc.cluster.local:8004
AUTONOMOUS_LEARNING_URL=http://autonomous-learning-engine.aileron.svc.cluster.local:8006
ALERTHUB_BERT_URL=http://alerthub-bert-service.aileron.svc.cluster.local:8765
LOCAL_BERT_URL=http://local-bert-service.aileron.svc.cluster.local:8765
INTEGRATION_PROXY_URL=http://integration-proxy.aileron.svc.cluster.local:8080
TOPOLOGY_GRAPH_ENGINE_URL=http://topology-graph.aileron.svc.cluster.local:8003
UNIVERSAL_ALERT_GATEWAY_URL=http://universal-alert-gateway.aileron.svc.cluster.local:8080
SECURITY_SCANNING_URL=http://security-scanning-engine.aileron.svc.cluster.local:8015
AI_SERVICES_MANAGER_URL=http://ai-services-manager.aileron.svc.cluster.local:8001
PERFORMANCE_OPTIMIZATION_URL=http://performance-optimization-engine.aileron.svc.cluster.local:8007
CHAOS_ENGINEERING_URL=http://chaos-engineering-service.aileron.svc.cluster.local:8008
DATABASE_OPTIMIZATION_URL=http://database-optimization-engine.aileron.svc.cluster.local:8009
DISASTER_RECOVERY_URL=http://disaster-recovery-service.aileron.svc.cluster.local:8010
MULTI_REGION_DEPLOYMENT_URL=http://multi-region-deployment-service.aileron.svc.cluster.local:8011

# Set to true during development to skip AI service health checks at startup
SKIP_AI_HEALTH_CHECK=false

# ⚠️  SECURITY NOTES:
# - Never commit this .env file to version control
# - Use different secrets for each environment
# - Rotate secrets regularly (every 90 days)
# - Monitor for unauthorized access attempts
# - Enable audit logging in production
# - Use TLS 1.3 minimum for all connections