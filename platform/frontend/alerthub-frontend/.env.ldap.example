# =====================================================
# SRE Command Center - LDAP Configuration Example
# =====================================================
# Copy this file to .env.local and update with your values

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/alerthub

# LDAP Configuration (Apple Internal)
LDAP_ENABLED=true
LDAP_SERVER=
LDAP_PORT=636
LDAP_BASE_DN=o=apple
LDAP_USER_SEARCH_BASE=ou=people
LDAP_USER_FILTER=appleconnectname=%s
LDAP_GROUP_SEARCH_BASE=ou=groups
LDAP_GROUP_FILTER=uniquemember=%s
LDAP_USE_TLS=true
LDAP_DISPLAY_NAME_ATTR=cn
LDAP_EMAIL_ATTR=mail
LDAP_UPDATE_INTERVAL=15

# LDAP Service Account (replace with your AppID)
LDAP_BIND_DN=appid=YOUR_APP_ID,ou=applications,o=apple
LDAP_BIND_PASSWORD=YOUR_APP_PASSWORD

# JWT Configuration
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRATION=24h
JWT_REFRESH_EXPIRATION=168h

# Application Configuration
APP_ENV=production
APP_PORT=8080
APP_HOST=0.0.0.0

# Cors Configuration
CORS_ORIGINS=https://your-alerthub-domain.apple.com

# Group to Role Mapping (comma-separated)
LDAP_ADMIN_GROUPS=int-service-delivery,interactive-apps-systems-FTE,interactive-systems-disclosed,aileron-admins
LDAP_MANAGER_GROUPS=interactive-apps-systems,interactive-release-engineering
LDAP_ENGINEER_GROUPS=interactive-apps-dev,interactive-release-operations,int-auto-sample-build
LDAP_VIEWER_GROUPS=iasys-rome-cigniti,interactive-rome-dev-team-core,marcom-dotcom-qa-tools

# Default role for users not in any specified group
LDAP_DEFAULT_ROLE=viewer

# Enable audit logging for LDAP authentication
LDAP_AUDIT_ENABLED=true

# Session Configuration
SESSION_TIMEOUT=86400
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTPONLY=true

# Frontend URL (for redirects)
FRONTEND_URL=https://your-alerthub-domain.apple.com
