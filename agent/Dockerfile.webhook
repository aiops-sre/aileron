FROM golang:1.22-alpine AS builder
WORKDIR /build
RUN apk add --no-cache ca-certificates tzdata
COPY go.mod go.sum* ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -ldflags="-s -w" -o /app/kubesense-webhook ./services/core/cmd/webhook

FROM scratch
COPY --from=builder /etc/ssl/certs/ca-certificates.crt /etc/ssl/certs/
COPY --from=builder /app/kubesense-webhook /kubesense-webhook
EXPOSE 8443
ENTRYPOINT ["/kubesense-webhook"]
