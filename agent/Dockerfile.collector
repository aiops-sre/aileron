FROM golang:1.22-alpine AS builder

ARG HTTP_PROXY
ARG HTTPS_PROXY
ARG NO_PROXY
ARG GOPROXY=https://proxy.golang.org,direct

ENV HTTP_PROXY=${HTTP_PROXY} \
    HTTPS_PROXY=${HTTPS_PROXY} \
    NO_PROXY=${NO_PROXY} \
    GOPROXY=${GOPROXY} \
    GONOSUMDB=* \
    GOFLAGS=-mod=mod \
    CGO_ENABLED=0 \
    GOOS=linux \
    GOARCH=amd64

WORKDIR /build

# Install your organizationorate Root CA so go mod download can verify TLS through the corporate proxy
RUN apk --no-cache add git ca-certificates
    || true
      update-ca-certificates; \
    fi
COPY go.mod ./
RUN go mod download
COPY . .
RUN go build -ldflags="-s -w -X main.version=${VERSION:-dev}" \
    -o /kubesense-collector \
    ./services/collector/cmd/collector/

FROM alpine:3.19 AS runtime
RUN apk --no-cache add ca-certificates && \
    addgroup -S kubesense && adduser -S kubesense -G kubesense
COPY --from=builder /kubesense-collector /usr/local/bin/kubesense-collector
USER kubesense:kubesense
EXPOSE 8082
ENTRYPOINT ["/usr/local/bin/kubesense-collector"]
