{
  "name": "kubesense-ui",
  "version": "1.0.0",
  "description": "KubeSense Intelligence IDE — the most advanced Kubernetes UI",
  "private": true,
  "type": "module",
  "scripts": {
    "dev":        "vite --port 3000",
