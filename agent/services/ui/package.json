    "zustand":                "^5.0.0",
    "@monaco-editor/react":   "^4.6.0",
    "@xyflow/react":          "^12.3.0",
    "framer-motion":          "^12.0.0",
    "lucide-react":           "^0.460.0",
    "xterm":                  "^5.3.0",
    "xterm-addon-fit":        "^0.8.0",
    "recharts":               "^2.12.7",
    "clsx":                   "^2.1.1",
    "date-fns":               "^3.6.0",
    "yaml":                   "^2.5.1",
    "cmdk":                   "^1.0.0",
